{
  "name": "@y-core/forge",
  "version": "0.0.11",
  "type": "module",
  "description": "Server-rendered web utilities for Hono + Cloudflare Workers",
  "scripts": {
    "typecheck": "tsgo --noEmit",
    "lint": "biome check src/",
    "lint:fix": "biome check --write src/",
    "test": "bun test",
    "check": "bun run typecheck && bun run lint && bun test && bun run validate-exports",
    "validate-exports": "bun run scripts/validate-exports.ts",
    "prepublishOnly": "bun run check",
    "release": "bun run scripts/release.ts"
  },
  "sideEffects": [
    "./src/ui/client/htmx.ts"
  ],
  "dependencies": {
    "@remix-run/cookie": "^0.5.1",
    "@remix-run/headers": "^0.19.0",
    "@remix-run/session": "^0.4.1",
    "hono": "^4.7.0",
    "htmx.org": "^2.0.10",
    "valibot": "^1.4.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.15",
    "@typescript/native-preview": "^7.0.0-dev.20260517.1",
    "esbuild": "^0.25.0"
  },
  "peerDependencies": {
    "esbuild": ">=0.20.0",
    "sharp": ">=0.33.0"
  },
  "peerDependenciesMeta": {
    "esbuild": {
      "optional": true
    },
    "sharp": {
      "optional": true
    }
  },
  "exports": {
    "./app": {
      "types": "./src/app/mod.ts",
      "import": "./src/app/mod.ts"
    },
    "./config": {
      "types": "./src/config/mod.ts",
      "import": "./src/config/mod.ts"
    },
    "./assets": {
      "types": "./src/assets/mod.ts",
      "import": "./src/assets/mod.ts"
    },
    "./assets/build": {
      "types": "./src/assets/build/mod.ts",
      "import": "./src/assets/build/mod.ts"
    },
    "./assets/manifest": {
      "types": "./src/assets/manifest/mod.ts",
      "import": "./src/assets/manifest/mod.ts"
    },
    "./cli": {
      "types": "./src/cli/mod.ts",
      "import": "./src/cli/mod.ts"
    },
    "./form": {
      "types": "./src/form/mod.ts",
      "import": "./src/form/mod.ts"
    },
    "./jsx/jsx-dev-runtime": {
      "types": "./src/jsx/jsx-dev-runtime.ts",
      "import": "./src/jsx/jsx-dev-runtime.ts"
    },
    "./jsx-dev-runtime": {
      "types": "./src/jsx/jsx-dev-runtime.ts",
      "import": "./src/jsx/jsx-dev-runtime.ts"
    },
    "./jsx-runtime": {
      "types": "./src/jsx/jsx-runtime.ts",
      "import": "./src/jsx/jsx-runtime.ts"
    },
    "./http": {
      "types": "./src/http/mod.ts",
      "import": "./src/http/mod.ts"
    },
    "./logging": {
      "types": "./src/logging/mod.ts",
      "import": "./src/logging/mod.ts"
    },
    "./logging/http": {
      "types": "./src/logging/http/mod.ts",
      "import": "./src/logging/http/mod.ts"
    },
    "./pkg": {
      "types": "./src/pkg/mod.ts",
      "import": "./src/pkg/mod.ts"
    },
    "./result": {
      "types": "./src/result/mod.ts",
      "import": "./src/result/mod.ts"
    },
    "./router": {
      "types": "./src/router/mod.ts",
      "import": "./src/router/mod.ts"
    },
    "./security": {
      "types": "./src/security/mod.ts",
      "import": "./src/security/mod.ts"
    },
    "./session": {
      "types": "./src/session/mod.ts",
      "import": "./src/session/mod.ts"
    },
    "./ui": {
      "types": "./src/ui/mod.ts",
      "import": "./src/ui/mod.ts"
    },
    "./ui/client": {
      "types": "./src/ui/client/mod.ts",
      "import": "./src/ui/client/mod.ts"
    },
    "./ui/client/htmx": {
      "types": "./src/ui/client/htmx.ts",
      "import": "./src/ui/client/htmx.ts"
    },
    "./storage/db": {
      "types": "./src/storage/db/mod.ts",
      "import": "./src/storage/db/mod.ts"
    },
    "./storage/kv": {
      "types": "./src/storage/kv/mod.ts",
      "import": "./src/storage/kv/mod.ts"
    },
    "./storage/r2": {
      "types": "./src/storage/r2/mod.ts",
      "import": "./src/storage/r2/mod.ts"
    },
    "./validation": {
      "types": "./src/validation/mod.ts",
      "import": "./src/validation/mod.ts"
    }
  },
  "files": [
    "scripts/",
    "src/app/",
    "src/assets/",
    "src/config/",
    "src/cli/",
    "src/form/",
    "src/http/",
    "src/jsx/",
    "src/logging/",
    "src/pkg/",
    "src/result/",
    "src/router/",
    "src/security/",
    "src/session/",
    "src/storage/",
    "src/ui/",
    "src/validation/",
    "templates/",
    "README.md",
    "!**/*.test.ts",
    "!**/*.test.tsx"
  ]
}
