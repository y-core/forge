{
  "compilerOptions": {
    "target": "ESNext",
    "lib": [
      "ESNext",
      "DOM",
      "DOM.Iterable"
    ],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    "noEmit": true,
    "isolatedModules": true,
    "verbatimModuleSyntax": true,
    "skipLibCheck": true,
    "types": [],
    "jsx": "react-jsx",
    "jsxImportSource": "@y-core/forge"
  },
  "include": [
    "src/**/*.ts",
    "src/**/*.tsx",
    ".types/**/*.d.ts"
  ]
}
